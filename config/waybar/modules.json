{
    "hyprland/workspaces": {
        "format": "{name}:{icon}",
        "on-click": "activate",
        "format-icons": {
            "1": "´ë¿",
            "2": "´äá",
            "3": "´äí",
            "active": "´åÆ",
            "default": "´äæ"
        },
        "sort-by-number": true
    },
    "hyprland/window": {
        "separate-outputs": true
    },
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%d/%m/%Y}",
        "timezone": "America/Argentina/Buenos_Aires",
        "on-click-right": "foot -e calcure",
        "tooltip": true,
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon} {capacity}%",
        "rotate": 0,
        "format-charging": "´çĞ {capacity}%",
        "format-plugged": "´çĞ {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "¾░éÄ",
            "¾░ü║",
            "¾░ü╗",
            "¾░ü╝",
            "¾░ü¢",
            "¾░ü¥",
            "¾░ü┐",
            "¾░éÇ",
            "¾░éü",
            "¾░éé",
            "¾░ü╣"
        ],
        "tooltip": true
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-icons": [
            "¯Åò",
            "¯Åù",
            "¯Å£",
            "¯Åá",
            "¯Åó",
            "¯Åú"
        ]
    },
    "wireplumber": {
        "max-volume": 150,
        "nospacing": 1,
        "tooltip": true,
        "scroll-step": 5,
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}%",
        "format-muted": "¾░Øş {volume}%",
        "on-click": "pavucontrol",
        "format-icons": [
            "´ÇĞ",
            "´Çğ",
            "´Ç¿"
        ]
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon} {artist} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) ´Çü",
        "format-disconnected": "Dekonetado nwnww ´Çü",
        "format-stopped": "{consumeIcon} Detenido ´Çü",
        "interval": 10,
        "on-click": "mpc toggle",
        "on-click-right": "foot -- ncmpcpp",
        "on-scroll-up": "mpc seek +3",
        "on-scroll-down": "mpc seek -3",
        "artist-len": 20,
        "title-len": 20,
        "consume-icons": {
            "on": "´âä "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">´ü┤</span> ",
            "on": "´ü┤ "
        },
        "repeat-icons": {
            "on": "´ÇŞ "
        },
        "single-icons": {
            "on": "´ÇŞ1 "
        },
        "state-icons": {
            "paused": "´üî",
            "playing": "´üï"
        },
        "tooltip-format": "MPD (conetado nwnw)",
        "tooltip-format-disconnected": "MPD (dekonetado nwnw)"
    },
    "custom/bluetooth": {
        "format": "´èö {}",
        "exec": "~/.config/waybar/scripts/bluetooth-display.sh",
        "interval": 2,
        "on-click": "blueman-manager",
        "return-type": "plain",
        "tooltip": true,
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "max-length": 25
    },
    "cpu": {
        "format": "´ïø {usage}%",
