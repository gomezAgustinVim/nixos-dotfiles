    },
    "tray": {
        "icon-size": 14,
        "rotate": 0,
        "spacing": 5,
        "tooltip": true
    },
    "memory": {
        "interval": 30,
        "format": "¯┐à  {used:0.1f}G/{total:0.1f}G",
        "max-length": 20
    }
}
